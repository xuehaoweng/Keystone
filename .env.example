# Public HTTP port exposed by the Nginx ingress container.
GATEWAY_PORT=8000
GATEWAY_KEY_ENCRYPTION_SECRET=change-me-in-production-use-openssl-rand-base64-32
GATEWAY_JWT_SECRET=your-secret-key-change-in-production

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
QWEN_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
KIMI_API_KEY=sk-...
# Kimi Code membership API key. Uses provider `kimi_code` and model `kimi-for-coding`.
KIMI_CODE_API_KEY=sk-kimi-...
LINGYA_API_KEY=sk-...
GLM_API_KEY=...

# Local development only. Docker Compose overrides this to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
